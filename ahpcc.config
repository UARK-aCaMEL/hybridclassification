/*
 * ──────────────────────────────────────────────────────────────
 *  AHPCC‑Pinnacle (public nodes)  ▸  NextFlow Slurm profile 
 *  Activate with:   -profile ahpcc,singularity
 *
 *  CPU routing
 *      ≤ 1 h       →  comp01
 *      ≤ 6 h       →  comp06
 *      ≤ 3 d       →  comp72
 *      ≤ 12 d      →  tres72
 *      mem ≥ 192 GB overrides to
 *                   himem06  (≤ 3 d)   |   himem72  (> 3 d)
 *
 *  GPUs (add corresponding labels in your processes)
 *      'gpu'       → 1 × V100      (gpu06 / gpu72)
 *      'gpu_a100'  → 1 × A100      (agpu06 / agpu72)
 *      'gpu4'      → 4 × A100      (qgpu06 / qgpu72)
 *
 *  Cluster caps:  cpus ≤ 480  |  mem ≤ 768 GB  |  wall ≤ 12 days
 *  Auto–CPU bump: ensures mem per core ≤ 6 GiB on comp* nodes
 *  Apptainer/Singularity binds: /scratch  /share  /storage
 * ──────────────────────────────────────────────────────────────
 */

//////////////////////////////////////
// nf‑core metadata                 //
//////////////////////////////////////
params {
    config_profile_description = 'Arkansas High Performance Computing Cluster profile (public partitions)'
    config_profile_contact     = 'Tyler Chafin (@tkchafin)'
    config_profile_url         = 'https://hpc.uark.edu'
}

//////////////////////////////////////
// global “hard limits”             //
//////////////////////////////////////
params.max_cpus   = 480
params.max_memory = 768.GB
params.max_time   = 12.day

//////////////////////////////////////
// constant for comp node quota     //
//////////////////////////////////////
def MEM_PER_CORE_MiB = 6000   // ≈192 GB ÷ 32 cores

//////////////////////////////////////
// default executor settings        //
//////////////////////////////////////
process {

    executor = 'slurm'

    //------------------------------------------------------------------
    // 1. choose the partition (“queue”)
    //------------------------------------------------------------------
    queue = {
        if( task.memory >= 192.GB )
            return task.time > 3.day ? 'himem72' : 'himem06'

        if( task.time <=  1.hour ) return 'comp01'
        if( task.time <=  6.hour ) return 'comp06'
        if( task.time <=  3.day  ) return 'comp72'
        if( task.time <= 12.day  ) return 'tres72'

        error "Requested runtime ${task.time} exceeds 12‑day cluster limit"
    }

    //------------------------------------------------------------------
    // 2. auto‑scale CPUs when mem/core would exceed node quota
    //------------------------------------------------------------------
    cpus = {
        // honour an explicit CPU request in the pipeline
        if( task.cpus && task.cpus > 1 )
            return task.cpus

        def need = Math.ceil( task.memory.toMega() / MEM_PER_CORE_MiB ) as int
        return need < 1 ? 1 : ( need > params.max_cpus ? params.max_cpus : need )
    }
}

/* ───────── GPU sections ───────── */

// 1 × V100
withLabel: gpu {
    queue          = { task.time > 3.day ? 'gpu72'  : 'gpu06' }
    clusterOptions = { '--gres=gpu:1' }
    containerOptions = {
        workflow.containerEngine == 'singularity'
            ? '--containall --cleanenv --nv'
            : ( workflow.containerEngine == 'docker' ? '--gpus all' : null )
    }
}

// 1 × A100
withLabel: gpu_a100 {
    queue          = { task.time > 3.day ? 'agpu72' : 'agpu06' }
    clusterOptions = { '--gres=gpu:1' }
    containerOptions = { workflow.containerEngine == 'singularity' ? '--containall --cleanenv --nv' : null }
}

// 4 × A100
withLabel: gpu4 {
    queue          = { task.time > 3.day ? 'qgpu72' : 'qgpu06' }
    clusterOptions = { '--gres=gpu:4' }
    containerOptions = { workflow.containerEngine == 'singularity' ? '--containall --cleanenv --nv' : null }
}

//////////////////////////////////////
// Slurm engine fine‑tuning         //
//////////////////////////////////////
executor {
    name              = 'slurm'
    queueStatInterval = '30 sec'
    submitRateLimit   = '5 sec'
    killBatchSize     = 50
}

//////////////////////////////////////
// Apptainer/Singularity binds      //
//////////////////////////////////////
singularity.runOptions = '--bind /scratch --bind /share --bind /storage --containall --cleanenv'
